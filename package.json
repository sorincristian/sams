{
  "name": "sams",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @sams/api prisma generate",
    "db:migrate": "pnpm --filter @sams/api prisma migrate dev"
  },
  "dependencies": {
    "prisma": "^5.22.0"
  }
}
