generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InventoryTransactionType {
  RECEIVE
  ISSUE
  TRANSFER_OUT
  TRANSFER_IN
  ADJUST_IN
  ADJUST_OUT
  RETURN
  SCRAP
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum InventoryStatus {
  NEW
  INSTALLED
  DIRTY
  PACKED_FOR_RETURN
  IN_TRANSIT_TO_VENDOR
  AT_VENDOR
  RETURNED_FROM_VENDOR
  DISPOSED
}

enum ReupholsteryBatchStatus {
  DRAFT
  PACKED
  SHIPPED
  RECEIVED_BY_VENDOR
  IN_REUPHOLSTERY
  READY_TO_RETURN
  RETURNED
  CLOSED
}

enum VendorOrderStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum VendorReceiptStatus {
  PENDING
  PARTIAL
  COMPLETED
  DISPUTED
}

enum RecordReason {
  TORN
  GRAFFITI
  FOAM_DAMAGE
  HARDWARE_DAMAGE
  OTHER
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum AlertType {
  LOW_NEW_INVENTORY
  HIGH_DIRTY_INVENTORY
  OVERDUE_REUPHOLSTERY_BATCH
  DISPOSAL_SPIKE
  REPLACEMENT_SPIKE
  INVENTORY_DISCREPANCY
  VENDOR_SLA_BREACH
  OVERDUE_VENDOR_RETURN
  OVERDUE_VENDOR_ORDER
  PARTIAL_RECEIPT_PENDING
}

model Garage {
  id                    String                 @id @default(cuid())
  code                  String                 @unique
  name                  String                 @unique
  buses                 Bus[]
  users                 User[]
  inventoryItems        InventoryItem[]
  workOrders            WorkOrder[]
  inventoryTransactions InventoryTransaction[]
  workOrderPartUsages   WorkOrderPartUsage[]
  userScopes            UserScope[]

  // Phase 15 Additions
  type                    String?
  thresholdNewInventory   Int                   @default(10)
  thresholdDirtyInventory Int                   @default(20)
  seatInserts             SeatInsert[]
  reupholsteryBatches     ReupholsteryBatch[]
  replacementActivities   ReplacementActivity[]
  disposalRecords         DisposalRecord[]
  alerts                  Alert[]
  vendorOrders            VendorOrder[]
  vendorReceipts          VendorReceipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bus {
  id                    String                @id @default(cuid())
  fleetNumber           String                @unique
  model                 String
  manufacturer          String
  status                String                @default("ACTIVE")
  garageId              String
  busCompatibilityId    String?
  garage                Garage                @relation(fields: [garageId], references: [id])
  busCompatibility      BusCompatibility?     @relation(fields: [busCompatibilityId], references: [id])
  workOrders            WorkOrder[]
  seatInserts           SeatInsert[]
  replacementActivities ReplacementActivity[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

model SeatInsertType {
  id                     String                 @id @default(cuid())
  partNumber             String                 @unique
  description            String
  vendor                 String
  compatibleBusModels    String[]               @default([])
  minStockLevel          Int                    @default(0)
  reorderPoint           Int                    @default(0)
  unitCost               Float                  @default(0)
  active                 Boolean                @default(true)
  // Phase 2: catalog import fields
  manufacturerPartNumber String?
  alternatePartNumbers   String[]               @default([])
  componentType          String? // BACK | CUSHION
  trimSpec               String?
  inventoryItems         InventoryItem[]
  inventoryTransactions  InventoryTransaction[]
  workOrderPartUsages    WorkOrderPartUsage[]
  busCompatibilities     BusCompatibility[]     @relation("SeatInsertBusCompat")
  catalogAttachments     CatalogAttachment[]
  diagramHotspots        DiagramHotspot[]
  vendorOrderLines       VendorOrderLine[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
}

model BusCompatibility {
  id              String              @id @default(cuid())
  busTypeLabel    String
  manufacturer    String
  modelFamily     String?
  propulsion      String?
  fleetRangeStart Int?
  fleetRangeEnd   Int?
  fleetRangeLabel String
  sourceSheet     String?
  sourceRow       Int?
  buses           Bus[]
  seatInsertTypes SeatInsertType[]    @relation("SeatInsertBusCompat")
  attachments     CatalogAttachment[]
  createdAt       DateTime            @default(now())

  @@unique([busTypeLabel, fleetRangeLabel])
}

model CatalogAttachment {
  id                 String            @id @default(cuid())
  seatInsertTypeId   String?
  busCompatibilityId String?
  fileName           String
  fileType           String
  attachmentType     String // DIAGRAM | PHOTO | INSTALL_GUIDE
  urlOrPath          String
  previewImageUrl    String? // PNG/WebP preview for hotspot overlay
  busTypeLabel       String?
  fleetRangeLabel    String?
  notes              String?
  isPrimary          Boolean           @default(false)
  seatInsertType     SeatInsertType?   @relation(fields: [seatInsertTypeId], references: [id])
  busCompatibility   BusCompatibility? @relation(fields: [busCompatibilityId], references: [id])
  hotspots           DiagramHotspot[]
  createdAt          DateTime          @default(now())
}

model DiagramHotspot {
  id                  String            @id @default(cuid())
  catalogAttachmentId String
  seatLabel           String
  partNumber          String
  seatInsertTypeId    String?
  x                   Float // normalized 0..1
  y                   Float
  width               Float
  height              Float
  shape               String            @default("rect")
  notes               String?
  catalogAttachment   CatalogAttachment @relation(fields: [catalogAttachmentId], references: [id], onDelete: Cascade)
  seatInsertType      SeatInsertType?   @relation(fields: [seatInsertTypeId], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model InventoryItem {
  id               String         @id @default(cuid())
  garageId         String
  seatInsertTypeId String
  quantity         Int            @default(0) // Legacy column kept for additive safety
  quantityOnHand   Int            @default(0)
  quantityReserved Int            @default(0)
  binLocation      String?
  garage           Garage         @relation(fields: [garageId], references: [id])
  seatInsertType   SeatInsertType @relation(fields: [seatInsertTypeId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([garageId, seatInsertTypeId])
}

model InventoryTransaction {
  id                String                   @id @default(cuid())
  seatInsertTypeId  String
  garageId          String
  quantity          Int
  type              InventoryTransactionType
  notes             String?
  referenceType     String?
  referenceId       String?
  performedByUserId String
  seatInsertType    SeatInsertType           @relation(fields: [seatInsertTypeId], references: [id])
  garage            Garage                   @relation(fields: [garageId], references: [id])
  performedByUser   User                     @relation(fields: [performedByUserId], references: [id])
  workOrderUsages   WorkOrderPartUsage[]
  createdAt         DateTime                 @default(now())
}

model WorkOrder {
  id               String               @id @default(cuid())
  workOrderNumber  String               @unique
  status           String               @default("OPEN")
  priority         String               @default("MEDIUM")
  issueDescription String
  busId            String
  garageId         String
  bus              Bus                  @relation(fields: [busId], references: [id])
  garage           Garage               @relation(fields: [garageId], references: [id])
  partUsages       WorkOrderPartUsage[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model WorkOrderPartUsage {
  id                     String                @id @default(cuid())
  workOrderId            String
  seatInsertTypeId       String
  garageId               String
  quantity               Int
  issuedByUserId         String
  inventoryTransactionId String?               @unique
  notes                  String?
  workOrder              WorkOrder             @relation(fields: [workOrderId], references: [id])
  seatInsertType         SeatInsertType        @relation(fields: [seatInsertTypeId], references: [id])
  garage                 Garage                @relation(fields: [garageId], references: [id])
  issuedByUser           User                  @relation(fields: [issuedByUserId], references: [id])
  inventoryTransaction   InventoryTransaction? @relation(fields: [inventoryTransactionId], references: [id])
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
}

model User {
  id                    String                 @id @default(cuid())
  name                  String
  email                 String                 @unique
  passwordHash          String
  role                  String
  roleId                String?
  roleRelation          Role?                  @relation(fields: [roleId], references: [id])
  garageId              String?
  garage                Garage?                @relation(fields: [garageId], references: [id])
  inventoryTransactions InventoryTransaction[]
  workOrderPartUsages   WorkOrderPartUsage[]
  auditLogs             AuditLog[]
  importMappings        ImportMapping[]
  scopes                UserScope[]
  createdInvites        UserInvite[]
  replacementActivities ReplacementActivity[]
  disposalRecords       DisposalRecord[]
  vendorReceipts        VendorReceipt[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model ImportMapping {
  id        String   @id @default(cuid())
  userId    String
  entity    String
  mapping   Json
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, entity])
}

// Phase 15: Seat Inserts Command Centre Models
model Vendor {
  id           String              @id @default(cuid())
  name         String              @unique
  type         String              @default("REUPHOLSTERY_VENDOR")
  contactName  String?
  contactEmail String?
  contactPhone String?
  active       Boolean             @default(true)
  batches      ReupholsteryBatch[]
  orders       VendorOrder[]
  receipts     VendorReceipt[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
}

model SeatInsert {
  id             String          @id @default(cuid())
  seatType       String
  color          String
  hardwareCode   String
  fleetType      String
  status         InventoryStatus @default(NEW)
  locationId     String
  batchId        String?
  installedBusId String?

  location     Garage             @relation(fields: [locationId], references: [id])
  batch        ReupholsteryBatch? @relation(fields: [batchId], references: [id])
  installedBus Bus?               @relation(fields: [installedBusId], references: [id])

  replacementActivities ReplacementActivity[]
  disposalRecords       DisposalRecord[]

  installedAt DateTime?
  dirtyAt     DateTime?
  packedAt    DateTime?
  returnedAt  DateTime?
  disposedAt  DateTime?
  deletedAt   DateTime?

  lastUpdatedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([locationId])
  @@index([batchId])
}

model ReupholsteryBatch {
  id                 String                  @id @default(cuid())
  batchNumber        String                  @unique
  garageId           String
  vendorId           String
  seatType           String
  color              String
  packedDate         DateTime
  shippedDate        DateTime?
  expectedReturnDate DateTime
  actualReturnDate   DateTime?
  onTimeReturn       Boolean?
  status             ReupholsteryBatchStatus @default(DRAFT)
  trackingNumber     String?
  notes              String?

  garage   Garage       @relation(fields: [garageId], references: [id])
  vendor   Vendor       @relation(fields: [vendorId], references: [id])
  inserts  SeatInsert[]
  receipts VendorReceipt[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model VendorOrder {
  id                   String           @id @default(cuid())
  orderNumber          String           @unique
  garageId             String
  vendorId             String
  status               VendorOrderStatus @default(DRAFT)
  submittedAt          DateTime?
  expectedDeliveryDate DateTime?
  receivedAt           DateTime?
  notes                String?

  garage   Garage            @relation(fields: [garageId], references: [id])
  vendor   Vendor            @relation(fields: [vendorId], references: [id])
  lines    VendorOrderLine[]
  receipts VendorReceipt[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model VendorOrderLine {
  id               String         @id @default(cuid())
  orderId          String
  seatInsertTypeId String
  quantityOrdered  Int
  quantityReceived Int            @default(0)

  order          VendorOrder    @relation(fields: [orderId], references: [id])
  seatInsertType SeatInsertType @relation(fields: [seatInsertTypeId], references: [id])
}

model VendorReceipt {
  id                  String              @id @default(cuid())
  type                String              // "BATCH_RETURN" | "ORDER_RECEIPT"
  reupholsteryBatchId String?
  vendorOrderId       String?
  garageId            String
  vendorId            String
  receivedAt          DateTime            @default(now())
  receivedBy          String
  status              VendorReceiptStatus @default(PENDING)
  notes               String?

  batch       ReupholsteryBatch? @relation(fields: [reupholsteryBatchId], references: [id])
  order       VendorOrder?       @relation(fields: [vendorOrderId], references: [id])
  garage      Garage             @relation(fields: [garageId], references: [id])
  vendor      Vendor             @relation(fields: [vendorId], references: [id])
  receivingUser User             @relation(fields: [receivedBy], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ReplacementActivity {
  id          String       @id @default(cuid())
  inventoryId String?
  busId       String?
  locationId  String
  replacedAt  DateTime     @default(now())
  reason      RecordReason
  notes       String?
  createdBy   String

  insert        SeatInsert? @relation(fields: [inventoryId], references: [id])
  bus           Bus?        @relation(fields: [busId], references: [id])
  location      Garage      @relation(fields: [locationId], references: [id])
  createdByUser User        @relation(fields: [createdBy], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([locationId, replacedAt])
}

model DisposalRecord {
  id          String       @id @default(cuid())
  inventoryId String?
  locationId  String
  disposedAt  DateTime     @default(now())
  reason      RecordReason
  notes       String?
  createdBy   String

  insert        SeatInsert? @relation(fields: [inventoryId], references: [id])
  location      Garage      @relation(fields: [locationId], references: [id])
  createdByUser User        @relation(fields: [createdBy], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([locationId, disposedAt])
}

model Alert {
  id             String        @id @default(cuid())
  type           AlertType
  severity       AlertSeverity
  title          String
  description    String
  locationId     String?
  entityType     String?
  entityId       String?
  status         AlertStatus   @default(OPEN)
  triggeredAt    DateTime      @default(now())
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  metadata       Json?

  location Garage? @relation(fields: [locationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, locationId, status])
}

model PurchaseOrder {
  id     String @id @default(cuid())
  number String @unique
}

model PurchaseOrderLine {
  id              String @id @default(cuid())
  purchaseOrderId String
}

// Phase 10: RBAC & Scopes
model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  permissions RolePermission[]
  users       User[]
  userInvites UserInvite[]
  createdAt   DateTime         @default(now())
}

model RolePermission {
  id     String @id @default(cuid())
  roleId String
  module String
  access String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
}

model UserScope {
  id       String @id @default(cuid())
  userId   String
  garageId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  garage   Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@unique([userId, garageId])
}

// Phase 13: Invitations & User Onboarding
model UserInvite {
  id              String       @id @default(cuid())
  email           String
  token           String       @unique
  roleId          String
  garageIds       String[]     @default([])
  expiresAt       DateTime
  usedAt          DateTime?
  status          InviteStatus @default(PENDING) // PENDING, ACCEPTED, EXPIRED, REVOKED
  createdByUserId String
  createdByUser   User         @relation(fields: [createdByUserId], references: [id])
  role            Role         @relation(fields: [roleId], references: [id])
  createdAt       DateTime     @default(now())
}
