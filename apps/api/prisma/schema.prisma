generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InventoryTransactionType {
  RECEIVE
  ISSUE
  TRANSFER_OUT
  TRANSFER_IN
  ADJUST_IN
  ADJUST_OUT
  RETURN
  SCRAP
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum StockClass {
  REPLACEMENT_AVAILABLE
  INSTALLED
  DIRTY_RECOVERY
  HARVEY_IN_PROGRESS
  SCRAPPED
}

enum ConditionSource {
  NEW
  REBUILT
}

enum ReservationStatus {
  RESERVED
  INSTALLED
  RELEASED
  EXPIRED
  BLOCKED
}

enum ReupholsteryBatchStatus {
  DRAFT
  PACKED
  SHIPPED
  RECEIVED_BY_VENDOR
  IN_REUPHOLSTERY
  READY_TO_RETURN
  RETURNED
  CLOSED
}

enum VendorOrderStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum SeatInsertCategory {
  CUSHION
  BACK
}

enum VendorReceiptStatus {
  PENDING
  PARTIAL
  COMPLETED
  DISPUTED
}

enum RecordReason {
  TORN
  GRAFFITI
  FOAM_DAMAGE
  HARDWARE_DAMAGE
  OTHER
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum AlertType {
  LOW_NEW_INVENTORY
  HIGH_DIRTY_INVENTORY
  OVERDUE_REUPHOLSTERY_BATCH
  DISPOSAL_SPIKE
  REPLACEMENT_SPIKE
  INVENTORY_DISCREPANCY
  VENDOR_SLA_BREACH
  OVERDUE_VENDOR_RETURN
  OVERDUE_VENDOR_ORDER
  PARTIAL_RECEIPT_PENDING
}

model Garage {
  id                    String                 @id @default(cuid())
  code                  String                 @unique
  name                  String                 @unique
  buses                 Bus[]
  users                 User[]
  inventoryItems        InventoryItem[]
  workOrders            WorkOrder[]
  inventoryTransactions InventoryTransaction[]
  workOrderPartUsages   WorkOrderPartUsage[]
  userScopes            UserScope[]

  // Phase 15 Additions
  type                    String?
  thresholdNewInventory   Int                   @default(10)
  thresholdDirtyInventory Int                   @default(20)
  seatInserts             SeatInsert[]
  reupholsteryBatches     ReupholsteryBatch[]
  replacementActivities   ReplacementActivity[]
  disposalRecords         DisposalRecord[]
  alerts                  Alert[]
  vendorOrders            VendorOrder[]
  vendorReceipts          VendorReceipt[]

  // Phase 25 Additions
  emailProfile   GarageEmailProfile?
  outboundEmails OutboundEmail[]
  seatOrders     SeatOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bus {
  id                      String                   @id @default(cuid())
  fleetNumber             String                   @unique
  model                   String
  manufacturer            String
  status                  String                   @default("ACTIVE")
  garageId                String
  busCompatibilityId      String?
  garage                  Garage                   @relation(fields: [garageId], references: [id])
  busCompatibility        BusCompatibility?        @relation(fields: [busCompatibilityId], references: [id])
  workOrders              WorkOrder[]
  seatInserts             SeatInsert[]
  replacementActivities   ReplacementActivity[]
  replacementReservations ReplacementReservation[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

model SeatInsertType {
  id                     String                 @id @default(cuid())
  partNumber             String                 @unique
  description            String
  vendor                 String
  compatibleBusModels    String[]               @default([])
  minStockLevel          Int                    @default(0)
  reorderPoint           Int                    @default(0)
  unitCost               Float                  @default(0)
  active                 Boolean                @default(true)
  // Phase 2: catalog import fields
  manufacturerPartNumber String?
  alternatePartNumbers   String[]               @default([])
  componentType          String? // BACK | CUSHION
  category               SeatInsertCategory?
  trimSpec               String?
  inventoryItems         InventoryItem[]
  inventoryTransactions  InventoryTransaction[]
  workOrderPartUsages    WorkOrderPartUsage[]
  seatInserts            SeatInsert[]
  busCompatibilities     BusCompatibility[]     @relation("SeatInsertBusCompat")
  catalogAttachments     CatalogAttachment[]
  diagramHotspots        DiagramHotspot[]
  vendorOrderLines       VendorOrderLine[]
  seatOrderLines         SeatOrderLine[] // Phase 25 Addition
  workOrders             WorkOrder[]

  // Project A: BOM Component Relationships
  components       BomComponent[] @relation("AssemblyComponents")
  usedInAssemblies BomComponent[] @relation("ComponentUsage")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BomComponent {
  id               String @id @default(cuid())
  parentAssemblyId String
  childComponentId String
  requiredQty      Int    @default(1)

  parentAssembly SeatInsertType @relation("AssemblyComponents", fields: [parentAssemblyId], references: [id], onDelete: Cascade)
  childComponent SeatInsertType @relation("ComponentUsage", fields: [childComponentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentAssemblyId, childComponentId])
}

model BusCompatibility {
  id              String              @id @default(cuid())
  busTypeLabel    String
  manufacturer    String
  modelFamily     String?
  propulsion      String?
  fleetRangeStart Int?
  fleetRangeEnd   Int?
  fleetRangeLabel String
  sourceSheet     String?
  sourceRow       Int?
  buses           Bus[]
  seatInsertTypes SeatInsertType[]    @relation("SeatInsertBusCompat")
  attachments     CatalogAttachment[]
  createdAt       DateTime            @default(now())

  @@unique([busTypeLabel, fleetRangeLabel])
}

model CatalogAttachment {
  id                 String            @id @default(cuid())
  seatInsertTypeId   String?
  busCompatibilityId String?
  fileName           String
  fileType           String
  attachmentType     String // DIAGRAM | PHOTO | INSTALL_GUIDE
  urlOrPath          String
  previewImageUrl    String? // PNG/WebP preview for hotspot overlay
  busTypeLabel       String?
  fleetRangeLabel    String?
  notes              String?
  isPrimary          Boolean           @default(false)
  seatInsertType     SeatInsertType?   @relation(fields: [seatInsertTypeId], references: [id])
  busCompatibility   BusCompatibility? @relation(fields: [busCompatibilityId], references: [id])
  hotspots           DiagramHotspot[]
  createdAt          DateTime          @default(now())
}

model DiagramHotspot {
  id                  String            @id @default(cuid())
  catalogAttachmentId String
  seatLabel           String
  partNumber          String
  seatInsertTypeId    String?
  x                   Float // normalized 0..1
  y                   Float
  width               Float
  height              Float
  shape               String            @default("rect")
  notes               String?
  catalogAttachment   CatalogAttachment @relation(fields: [catalogAttachmentId], references: [id], onDelete: Cascade)
  seatInsertType      SeatInsertType?   @relation(fields: [seatInsertTypeId], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model InventoryItem {
  id               String         @id @default(cuid())
  garageId         String
  seatInsertTypeId String
  quantity         Int            @default(0) // Legacy column kept for additive safety
  quantityOnHand   Int            @default(0)
  quantityReserved Int            @default(0)
  binLocation      String?
  garage           Garage         @relation(fields: [garageId], references: [id])
  seatInsertType   SeatInsertType @relation(fields: [seatInsertTypeId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([garageId, seatInsertTypeId])
}

model InventoryTransaction {
  id                String                   @id @default(cuid())
  seatInsertTypeId  String
  garageId          String
  quantity          Int
  type              InventoryTransactionType
  notes             String?
  referenceType     String?
  referenceId       String?
  performedByUserId String
  seatInsertType    SeatInsertType           @relation(fields: [seatInsertTypeId], references: [id])
  garage            Garage                   @relation(fields: [garageId], references: [id])
  performedByUser   User                     @relation(fields: [performedByUserId], references: [id])
  workOrderUsages   WorkOrderPartUsage[]
  createdAt         DateTime                 @default(now())
}

model WorkOrder {
  id               String  @id @default(cuid())
  workOrderNumber  String  @unique
  status           String  @default("OPEN")
  priority         String  @default("MEDIUM")
  issueDescription String
  busId            String
  garageId         String
  seatInsertTypeId String?

  bus                     Bus                      @relation(fields: [busId], references: [id])
  garage                  Garage                   @relation(fields: [garageId], references: [id])
  seatInsertType          SeatInsertType?          @relation(fields: [seatInsertTypeId], references: [id])
  partUsages              WorkOrderPartUsage[]
  replacementReservations ReplacementReservation[]
  
  installedByUserId       String?
  closedByUserId          String?
  installedByUser         User?                    @relation("WorkOrderInstaller", fields: [installedByUserId], references: [id])
  closedByUser            User?                    @relation("WorkOrderCloser", fields: [closedByUserId], references: [id])

  closedAt                DateTime?
  closedNotes             String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

model WorkOrderPartUsage {
  id                     String                @id @default(cuid())
  workOrderId            String
  seatInsertTypeId       String
  garageId               String
  quantity               Int
  issuedByUserId         String
  inventoryTransactionId String?               @unique
  notes                  String?
  workOrder              WorkOrder             @relation(fields: [workOrderId], references: [id])
  seatInsertType         SeatInsertType        @relation(fields: [seatInsertTypeId], references: [id])
  garage                 Garage                @relation(fields: [garageId], references: [id])
  issuedByUser           User                  @relation(fields: [issuedByUserId], references: [id])
  inventoryTransaction   InventoryTransaction? @relation(fields: [inventoryTransactionId], references: [id])
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  passwordHash            String
  role                    String
  roleId                  String?
  roleRelation            Role?                    @relation(fields: [roleId], references: [id])
  garageId                String?
  garage                  Garage?                  @relation(fields: [garageId], references: [id])
  inventoryTransactions   InventoryTransaction[]
  workOrderPartUsages     WorkOrderPartUsage[]
  auditLogs               AuditLog[]
  importMappings          ImportMapping[]
  scopes                  UserScope[]
  createdInvites          UserInvite[]
  replacementActivities   ReplacementActivity[]
  disposalRecords         DisposalRecord[]
  vendorReceipts          VendorReceipt[]
  replacementReservations ReplacementReservation[]

  // Phase 25 Additions
  createdSeatOrders            SeatOrder[]           @relation("OrderCreator")
  approvedSeatOrders           SeatOrderApproval[]   @relation("OrderApprover")
  receivedSeatOrders           SeatOrderReceipt[]    @relation("OrderReceiver")
  uploadedSeatOrderAttachments SeatOrderAttachment[] @relation("OrderAttachmentUploader")
  
  installedWorkOrders          WorkOrder[]           @relation("WorkOrderInstaller")
  closedWorkOrders             WorkOrder[]           @relation("WorkOrderCloser")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tokenVersion Int      @default(0)
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model ImportMapping {
  id        String   @id @default(cuid())
  userId    String
  entity    String
  mapping   Json
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, entity])
}

// Phase 15: Seat Inserts Command Centre Models
model Vendor {
  id           String              @id @default(cuid())
  name         String              @unique
  type         String              @default("REUPHOLSTERY_VENDOR")
  contactName  String?
  contactEmail String?
  contactPhone String?
  active       Boolean             @default(true)
  batches      ReupholsteryBatch[]
  orders       VendorOrder[]
  receipts     VendorReceipt[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
}

model SeatInsert {
  id                String           @id @default(cuid())
  seatType          String
  color             String
  hardwareCode      String
  fleetType         String
  stockClass        StockClass       @default(REPLACEMENT_AVAILABLE)
  conditionSource   ConditionSource?
  locationId        String
  batchId           String?
  installedBusId    String?
  seatInsertTypeId  String?
  vendorOrderLineId String?

  location        Garage             @relation(fields: [locationId], references: [id])
  batch           ReupholsteryBatch? @relation(fields: [batchId], references: [id])
  installedBus    Bus?               @relation(fields: [installedBusId], references: [id])
  seatInsertType  SeatInsertType?    @relation(fields: [seatInsertTypeId], references: [id])
  vendorOrderLine VendorOrderLine?   @relation(fields: [vendorOrderLineId], references: [id])

  replacementActivities ReplacementActivity[]
  disposalRecords       DisposalRecord[]
  reservations          ReplacementReservation[]

  installedAt DateTime?
  dirtyAt     DateTime?
  packedAt    DateTime?
  returnedAt  DateTime?
  disposedAt  DateTime?
  deletedAt   DateTime?

  lastUpdatedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([locationId, stockClass, conditionSource])
  @@index([batchId])
}

model ReupholsteryBatch {
  id                 String                  @id @default(cuid())
  batchNumber        String                  @unique
  garageId           String
  vendorId           String
  seatType           String
  color              String
  packedDate         DateTime
  shippedDate        DateTime?
  expectedReturnDate DateTime
  actualReturnDate   DateTime?
  onTimeReturn       Boolean?
  status             ReupholsteryBatchStatus @default(DRAFT)
  trackingNumber     String?
  notes              String?

  garage   Garage          @relation(fields: [garageId], references: [id])
  vendor   Vendor          @relation(fields: [vendorId], references: [id])
  inserts  SeatInsert[]
  receipts VendorReceipt[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model VendorOrder {
  id                   String            @id @default(cuid())
  orderNumber          String            @unique
  garageId             String
  vendorId             String
  status               VendorOrderStatus @default(DRAFT)
  submittedAt          DateTime?
  expectedDeliveryDate DateTime?
  receivedAt           DateTime?
  notes                String?

  garage   Garage            @relation(fields: [garageId], references: [id])
  vendor   Vendor            @relation(fields: [vendorId], references: [id])
  lines    VendorOrderLine[]
  receipts VendorReceipt[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model VendorOrderLine {
  id               String @id @default(cuid())
  orderId          String
  seatInsertTypeId String
  quantityOrdered  Int
  quantityReceived Int    @default(0)

  order          VendorOrder    @relation(fields: [orderId], references: [id])
  seatInsertType SeatInsertType @relation(fields: [seatInsertTypeId], references: [id])
  seatInserts    SeatInsert[]
}

model VendorReceipt {
  id                  String              @id @default(cuid())
  type                String // "BATCH_RETURN" | "ORDER_RECEIPT"
  reupholsteryBatchId String?
  vendorOrderId       String?
  garageId            String
  vendorId            String
  receivedAt          DateTime            @default(now())
  receivedBy          String
  status              VendorReceiptStatus @default(PENDING)
  notes               String?

  batch         ReupholsteryBatch? @relation(fields: [reupholsteryBatchId], references: [id])
  order         VendorOrder?       @relation(fields: [vendorOrderId], references: [id])
  garage        Garage             @relation(fields: [garageId], references: [id])
  vendor        Vendor             @relation(fields: [vendorId], references: [id])
  receivingUser User               @relation(fields: [receivedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReplacementActivity {
  id          String       @id @default(cuid())
  inventoryId String?
  busId       String?
  locationId  String
  replacedAt  DateTime     @default(now())
  reason      RecordReason
  notes       String?
  createdBy   String

  insert        SeatInsert? @relation(fields: [inventoryId], references: [id])
  bus           Bus?        @relation(fields: [busId], references: [id])
  location      Garage      @relation(fields: [locationId], references: [id])
  createdByUser User        @relation(fields: [createdBy], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([locationId, replacedAt])
}

model DisposalRecord {
  id          String       @id @default(cuid())
  inventoryId String?
  locationId  String
  disposedAt  DateTime     @default(now())
  reason      RecordReason
  notes       String?
  createdBy   String

  insert        SeatInsert? @relation(fields: [inventoryId], references: [id])
  location      Garage      @relation(fields: [locationId], references: [id])
  createdByUser User        @relation(fields: [createdBy], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([locationId, disposedAt])
}

model Alert {
  id             String        @id @default(cuid())
  type           AlertType
  severity       AlertSeverity
  title          String
  description    String
  locationId     String?
  entityType     String?
  entityId       String?
  status         AlertStatus   @default(OPEN)
  triggeredAt    DateTime      @default(now())
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  metadata       Json?

  location Garage? @relation(fields: [locationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, locationId, status])
}

model PurchaseOrder {
  id     String @id @default(cuid())
  number String @unique
}

model PurchaseOrderLine {
  id              String @id @default(cuid())
  purchaseOrderId String
}

// Phase 10: RBAC & Scopes
model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  permissions RolePermission[]
  users       User[]
  userInvites UserInvite[]
  createdAt   DateTime         @default(now())
}

model RolePermission {
  id     String @id @default(cuid())
  roleId String
  module String
  access String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
}

model UserScope {
  id       String @id @default(cuid())
  userId   String
  garageId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  garage   Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@unique([userId, garageId])
}

// Phase 13: Invitations & User Onboarding
model UserInvite {
  id              String       @id @default(cuid())
  email           String
  token           String       @unique
  roleId          String
  garageIds       String[]     @default([])
  expiresAt       DateTime
  usedAt          DateTime?
  status          InviteStatus @default(PENDING) // PENDING, ACCEPTED, EXPIRED, REVOKED
  createdByUserId String
  createdByUser   User         @relation(fields: [createdByUserId], references: [id])
  role            Role         @relation(fields: [roleId], references: [id])
  createdAt       DateTime     @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model RateLimit {
  key       String   @id
  points    Int      @default(0)
  expiresAt DateTime
}

// ─── Phase 25: Seat Inserts Order Centre & Email Management ───────────────

enum SeatOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENDING
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  INSTALLED
  CLOSED
  CANCELLED
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  DELIVERED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model GarageEmailProfile {
  id            String  @id @default(cuid())
  garageId      String  @unique
  fromName      String
  fromEmail     String
  replyToEmail  String
  signatureHtml String?
  harveyToEmail String
  defaultCc     String?
  defaultBcc    String?
  providerType  String  @default("SMTP")
  active        Boolean @default(true)

  garage    Garage   @relation(fields: [garageId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  subjectTemplate  String
  bodyHtmlTemplate String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OutboundEmail {
  id                String      @id @default(cuid())
  garageId          String
  to                String
  cc                String?
  bcc               String?
  subject           String
  bodyHtml          String
  status            EmailStatus @default(QUEUED)
  providerMessageId String?
  errorMessage      String?
  attempts          Int         @default(0)
  lockedUntil       DateTime?
  templateCode      String      @default("SEAT_ORDER_HARVEY")

  garage      Garage            @relation(fields: [garageId], references: [id])
  events      EmailAuditEvent[]
  seatOrderId String?
  seatOrder   SeatOrder?        @relation(fields: [seatOrderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailAuditEvent {
  id               String      @id @default(cuid())
  emailId          String
  status           EmailStatus
  message          String?
  providerResponse String?

  email     OutboundEmail @relation(fields: [emailId], references: [id])
  createdAt DateTime      @default(now())
}

model SeatOrder {
  id            String          @id @default(cuid())
  orderNumber   String          @unique
  garageId      String
  status        SeatOrderStatus @default(DRAFT)
  totalCost     Float           @default(0)
  totalQuantity Int             @default(0)
  notes         String?

  createdByUserId String
  submittedAt     DateTime?
  approvedAt      DateTime?
  sentAt          DateTime?

  garage        Garage @relation(fields: [garageId], references: [id])
  createdByUser User   @relation("OrderCreator", fields: [createdByUserId], references: [id])

  outboundEmails OutboundEmail[]

  lines       SeatOrderLine[]
  approvals   SeatOrderApproval[]
  receipts    SeatOrderReceipt[]
  attachments SeatOrderAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeatOrderLine {
  id               String  @id @default(cuid())
  seatOrderId      String
  seatInsertTypeId String
  quantity         Int
  unitCost         Float
  description      String?

  order          SeatOrder              @relation(fields: [seatOrderId], references: [id])
  seatInsertType SeatInsertType         @relation(fields: [seatInsertTypeId], references: [id])
  receipts       SeatOrderReceiptLine[]
}

model SeatOrderApproval {
  id               String         @id @default(cuid())
  seatOrderId      String
  approvedByUserId String
  status           ApprovalStatus @default(PENDING)
  notes            String?

  order          SeatOrder @relation(fields: [seatOrderId], references: [id], onDelete: Cascade)
  approvedByUser User      @relation("OrderApprover", fields: [approvedByUserId], references: [id])
  createdAt      DateTime  @default(now())
}

model SeatOrderReceipt {
  id               String  @id @default(cuid())
  seatOrderId      String
  receivedByUserId String
  notes            String?

  order          SeatOrder              @relation(fields: [seatOrderId], references: [id])
  receivedByUser User                   @relation("OrderReceiver", fields: [receivedByUserId], references: [id])
  lines          SeatOrderReceiptLine[]

  createdAt DateTime @default(now())
}

model SeatOrderReceiptLine {
  id              String @id @default(cuid())
  receiptId       String
  seatOrderLineId String
  receivedQty     Int

  receipt       SeatOrderReceipt @relation(fields: [receiptId], references: [id])
  seatOrderLine SeatOrderLine    @relation(fields: [seatOrderLineId], references: [id])
}

model SeatOrderAttachment {
  id               String @id @default(cuid())
  seatOrderId      String
  fileUrl          String
  fileName         String
  uploadedByUserId String

  order          SeatOrder @relation(fields: [seatOrderId], references: [id])
  uploadedByUser User      @relation("OrderAttachmentUploader", fields: [uploadedByUserId], references: [id])

  createdAt DateTime @default(now())
}

model ReplacementReservation {
  id                    String            @id @default(cuid())
  workOrderId           String?
  busId                 String?
  seatPosition          String?
  actualInventoryUnitId String?
  status                ReservationStatus @default(RESERVED)
  expiresAt             DateTime?
  reservedByUserId      String

  workOrder      WorkOrder?  @relation(fields: [workOrderId], references: [id])
  bus            Bus?        @relation(fields: [busId], references: [id])
  inventoryUnit  SeatInsert? @relation(fields: [actualInventoryUnitId], references: [id])
  reservedByUser User        @relation(fields: [reservedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
